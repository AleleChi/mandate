# GEMINI_API_KEY: Required for Gemini AI API calls.
# AI Studio automatically injects this at runtime from user secrets.
# Users configure this via the Secrets panel in the AI Studio UI.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="MY_APP_URL"

# DATABASE_URL: PostgreSQL connection string for production deployment.
# When set, the backend uses PostgreSQL instead of local SQLite.
DATABASE_URL="postgresql://user:password@hostname:5432/koinonia_db"

# JWT_SECRET: Secret signing key for parent session JSON Web Tokens.
JWT_SECRET="your-secure-random-jwt-signing-key"

# MEDIA_PROVIDER: Media storage provider ('cloudinary' or 'local').
MEDIA_PROVIDER="cloudinary"

# Cloudinary credentials and setup for media persistence.
# CLOUDINARY_API_SECRET must only be used on the server.
CLOUDINARY_CLOUD_NAME=""
CLOUDINARY_API_KEY=""
CLOUDINARY_API_SECRET=""
CLOUDINARY_UPLOAD_FOLDER="koinonia-children-teens"
CLOUDINARY_SECURE_DELIVERY="true"

# Transactional Email Notification Configuration (Backend Only)
# Note: Resend is the active email provider using a verified sending subdomain.
# RESEND_API_KEY must only be used on the server and must never be prefixed with VITE_.
# Frontend must never call Resend directly.
EMAIL_PROVIDER="resend"
RESEND_API_KEY=""
MAIL_FROM_NAME="Koinonia Children and Teens"
MAIL_FROM_ADDRESS="hello@parent-access.koinoniachildren.org"

# APP_BASE_URL: Base frontend URL. Must NOT contain a trailing slash.
# Local:
# APP_BASE_URL=http://localhost:5173
#
# Production:
# APP_BASE_URL=https://koinonia12.netlify.app
#
# If missing, the backend will throw an error in development and reject sending simulated/localhost links in production.
# Note: Verification links will append "/#/parent/verify-email?token=" for hash-routing compatibility.
APP_BASE_URL="http://localhost:5173"

# CORS_ORIGIN: Allowed CORS Origin for secure backend access.
# Local:
# CORS_ORIGIN=http://localhost:5173
#
# Production:
# CORS_ORIGIN=https://koinonia12.netlify.app
CORS_ORIGIN="http://localhost:5173"

# VITE_API_BASE_URL: Base backend URL for frontend client.
# Local (development fallback): VITE_API_BASE_URL="" (or leave empty to use local proxies)
# Production: VITE_API_BASE_URL="https://mandate-2i7u.onrender.com"
VITE_API_BASE_URL=""

# Optional legacy fallback (deprecated, do not use as active provider)
# SMTP_PROVIDER=""


